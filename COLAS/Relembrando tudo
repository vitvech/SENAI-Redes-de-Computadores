            FTP: 
                                apt install proftpd -y
                                nano /etc/proftpd/proftpd.conf
                                COlocar UseIPv6 on como off (UseIPv6 on)
                                 Descomentar DefaultRoot ~
                                            RequireValidShell off
                                            port 21
                                systemctl restart proftpd
                                mkdir  /var/ftpteste
                                useradd naufal -d /var/ftpteste -s /bin/false
                                passwd naufal
                                chown naufal:root /var/ftpteste
            
