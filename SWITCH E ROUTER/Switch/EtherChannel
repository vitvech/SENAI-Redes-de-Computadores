

PAGP = Port Aggregation Protocol (CISCO)
LACP = Link Aggregation Control Protocol (PROTOCOLO ABERTO)


!Escolher qual protocolo usar no EtherChannel
enable
config t
int range <n°-da-interface>  !Exemplo: int range g0/1-2

channel-protocol ?
         pagp      Use PAgP protocol
         lacp      Use LACP protocol

!lacp prepara interface para o LACP PROTOCOl
!pagp prepara interface para o PAgP PROTOCOl

channel-protocol lacp !ou pagp



!Escolher qual o grupo as portas fisicas vão trabalhar (POL) LACP

channel-group <1-6>
channel-group 1 mode <active-passive>
channel-group 1 mode active !LACP


!Escolher qual o grupo as portas fisicas vão trabalhar (POL) PAGP

channel-group <1-6>
channel-group 1 mode <desirable-auto>
channel-group 1 mode auto !PAgP


!Verificar os detalhes do ETH (etherchannel)
ENABLE
show etherchannel
show etherchannel
show etherchannel load-balance
show etherchannel port-channel
show eth summary

!Deixas as interfaces em modo default (remover etherchannel)
enable
config t
default int range <n°-da-interface>
           default int range f0/1-2




