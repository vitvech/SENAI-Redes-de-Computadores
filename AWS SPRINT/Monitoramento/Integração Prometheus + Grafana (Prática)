# ☁️ INSTALAR CLOUDWATCH AGENT

```bash
sudo dnf install -y amazon-cloudwatch-agent
```

---

# CRIAR CONFIGURAÇÃO CLOUDWATCH

```bash
sudo tee /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'EOF'
{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "cwagent"
  },
  "metrics": {
    "namespace": "LearnerLab/EC2",
    "metrics_collected": {
      "mem": {
        "measurement": ["mem_used_percent"]
      },
      "disk": {
        "measurement": ["disk_used_percent"],
        "resources": ["/"]
      }
    }
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/lab-app/app.log",
            "log_group_name": "/learner-lab/app",
            "log_stream_name": "{instance_id}"
          }
        ]
      }
    }
  }
}
EOF

```

---

# INICIAR AGENT

```bash
sudo /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
-a fetch-config -m ec2 \
-c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json -s
```

---

# CRIAR LOGS

```bash
sudo mkdir -p /var/log/lab-app

sudo touch /var/log/lab-app/app.log

sudo chmod 644 /var/log/lab-app/app.log
```

---

# GERAR LOGS

```bash
echo "$(date) INFO: aplicacao iniciada" | sudo tee -a /var/log/lab-app/app.log

echo "$(date) ERROR: conexao recusada no banco" | sudo tee -a /var/log/lab-app/app.log
```

