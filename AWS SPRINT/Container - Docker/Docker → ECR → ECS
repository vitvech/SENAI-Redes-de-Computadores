        #Fazer o registro da tarefa e definir os parametros
        aws ecs register-task-definition `
        --cli-input-json file://task-definition.json `
        --region $REGION


        #procurando automaticamente a VPC padrão da sua conta AWS e guardando o ID dela em uma variável para usar depois em outros comandos.
     
        $VPC_ID = aws ec2 describe-vpcs `
        --filters Name=isDefault,Values=true `
        --query "Vpcs[0].VpcId" --output text --region $REGION

        #procurando uma subnet dentro da VPC e salvando o ID dela na variável $SUBNET_ID

        $SUBNET_ID = aws ec2 describe-subnets `
         --filters Name=vpc-id,Values=$VPC_ID `
         --query "Subnets[0].SubnetId" --output text --region $REGION


        #criando um Security Group na AWS dentro da VPC escolhida e salvando o ID dele na variável $SG_ID.

        $SG_ID = aws ec2 create-security-group `
         --group-name ecs-sg `
         --description "ECS Security Group" `
          --vpc-id $VPC_ID `
         --query GroupId --output text --region $REGION

        #adiciona uma regra no Security Group permitindo conexões HTTP (porta 80) vindas de qualquer lugar da internet.
        aws ec2 authorize-security-group-ingress `
        --group-id $SG_ID `
        --protocol tcp `
        --port 80 `
        --cidr 0.0.0.0/0 `
        --region $REGION

                        OBS: 
                                Possivel erro: 
                                                An error occurred (InvalidGroup.Duplicate) when calling the CreateSecurityGroup operation:
                                                The security group 'ecs-sg' already exists for VPC 'vpc-xxxxxxxx'

                                Motivo: O Security Group chamado ecs-sg já existia dentro da VPC.

                                        Na AWS:

                                        nomes de Security Groups precisam ser únicos dentro da mesma VPC
                                        portanto a criação falhou

                                        Como o comando falhou:

                                        nenhum novo Security Group foi criado
                                        $SG_ID ficou vazio
                                
                                Solução:
                                        Em vez de criar um novo Security Group, foi utilizado o grupo já existente.
                                        Ou apagar o grupo existente e criar o novo

                                Comando usado para solucionar:
                                $SG_ID = aws ec2 describe-security-groups `
                                --filters Name=group-name,Values=ecs-sg `
                                --query "SecurityGroups[0].GroupId" `
                                --output text `
                                --region $REGION
                                                O que ele faz:
                                                                        lista os Security Groups
                                                                        filtra pelo nome ecs-sg
                                                                        pega apenas o GroupId
                                                                        salva o valor em $SG_ID

                                O comando de liberação da porta funcionou normalmente:
                                aws ec2 authorize-security-group-ingress `
                                --group-id $SG_ID `
                                --protocol tcp `
                                --port 80 `
                                --cidr 0.0.0.0/0 `
                                --region $REGION






