ip add 172.31.99.3 255.255.255.0


!Parte 2
!Etapa 1
exit
span mode pvst

!Etapa 2
span vlan 20,40,60,80,99 root primary

do show span 

!Parte 3
!Etapa 1
int range f0/5-24
